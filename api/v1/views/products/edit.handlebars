<div class="card">
  <div class="stack">
    <h1 class="h1">עריכת מוצר</h1>

    {{#if error}}
      <div class="alert alert-error">{{error}}</div>
    {{/if}}

    <form class="form" method="post" action="/products/{{product._id}}">
      <div class="field">
        <label>שם מוצר</label>
        <input class="input" name="name" value="{{product.name}}" />
      </div>

      <div class="field">
        <label>מחיר</label>
        <input class="input" name="price" type="number" step="0.01" value="{{product.price}}" />
      </div>

      <div class="field">
        <label>יחידות</label>
        <input class="input" name="unit" value="{{product.unit}}" />
      </div>

      <button class="btn btn-primary" type="submit">עדכן</button>
    </form>
  </div>
</div>