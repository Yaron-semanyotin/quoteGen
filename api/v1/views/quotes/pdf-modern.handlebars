<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <base href="{{baseUrl}}/" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;700&display=swap" rel="stylesheet">

  <style>
    *{
      box-sizing: border-box;
    }

    body{
      font-family: "Noto Sans Hebrew", Arial, sans-serif;
      direction: rtl;
      margin: 0;
      color:#111;
      padding: 18px;
    }

    .card{
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 16px;
    }

    .band{
      height: 10px;
      border-radius: 10px;
      background: {{quote.themeColor}};
      margin-bottom: 14px;
    }

    .topRow{
      display:flex;
      justify-content:space-between;
      gap: 12px;
      align-items:flex-start;
    }

    .biz{
      font-size: 18px;
      font-weight: 700;
    }

    .title{
      opacity: .85;
      margin-top: 2px;
    }

    .date{
      opacity: .8;
      text-align:left;
      white-space:nowrap;
    }

    table{
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
      font-size: 12.5px;
      table-layout: fixed;
    }

    colgroup col:nth-child(1){ width:44%; }
    colgroup col:nth-child(2){ width:10%; }
    colgroup col:nth-child(3){ width:14%; }
    colgroup col:nth-child(4){ width:16%; }
    colgroup col:nth-child(5){ width:16%; }

    th,
    td{
      border: 1px solid #e5e7eb;
      padding: 8px;
      vertical-align: top;
      min-width: 0;
      white-space: normal;
    }

    th{
      background: #f9fafb;
      font-weight: 700;
      text-align: center;
    }

    td.numCell{
      white-space: nowrap;
      text-align: center;
    }

    .centerCell{
      text-align: center;
    }

    .total{
      margin-top: 12px;
      font-weight: 700;
      font-size: 14px;
      text-align:left;
    }

    .logo{
      max-height: 50px;
      max-width: 140px;
      object-fit: contain;
      display:block;
      margin-bottom: 8px;
    }
  </style>
</head>

<body>
  <div class="card">
    <div class="band"></div>

    <div class="topRow">
      <div>
        {{#if quote.logoUrl}}
          <img class="logo" src="{{quote.logoUrl}}" />
        {{/if}}

        <div class="biz">{{{hardBreakEvery quote.businessName 20}}}</div>
        <div class="title">{{{hardBreakEvery quote.title 20}}}</div>
      </div>

      <div class="date">{{quote.quoteDate}}</div>
    </div>

    <table>
      <colgroup>
        <col><col><col><col><col>
      </colgroup>

      <thead>
        <tr>
          <th>מוצר</th>
          <th>כמות</th>
          <th>יחידה</th>
          <th>מחיר</th>
          <th>סה״כ</th>
        </tr>
      </thead>

      <tbody>
        {{#if quote.items.length}}
          {{#each quote.items}}
            <tr>
              <td>{{{hardBreakEvery this.name 20}}}</td>
              <td class="numCell">{{this.qty}}</td>
              <td class="centerCell">{{{hardBreakEvery this.unit 20}}}</td>
              <td class="numCell">{{formatMoney this.price}}</td>
              <td class="numCell">{{calcLineTotal this.qty this.price}}</td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="5" style="text-align:center;opacity:.7;">אין שורות</td>
          </tr>
        {{/if}}
      </tbody>
    </table>

    <div class="total">
      סה״כ לתשלום: {{formatMoney total}}
    </div>
  </div>
</body>
</html>