<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <base href="{{baseUrl}}/">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --theme: {{quote.themeColor}};
      --text: #111;
      --muted: #6b7280;
      --line: var(--theme);
      --bg: #fff;
    }

    *{
      box-sizing: border-box;
    }

    html,
    body{
      margin: 0;
      padding: 0;
      background: #fff;
      font-family: "Noto Sans Hebrew", Arial, sans-serif;
      color: var(--text);
      direction: rtl;
    }

    .page{
      width: 100%;
      min-height: auto;
      margin: 0;
      background: var(--bg);
      padding: 12mm;
      box-shadow: none;
      border-radius: 0;
    }

    .header{
      position: relative;
      border-bottom: 2px solid var(--theme);
      margin-bottom: 14px;
      padding: 80px 12px 12px 120px;
    }

    .logoCorner{
      position: absolute;
      top: 10px;
      left: 20px;
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      background: #fff;
      border: none;
    }

    .topRow{
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .biz{
      font-size: 16px;
      font-weight: 800;
      line-height: 1.2;
    }

    .slogan{
      margin-top: 4px;
      font-size: 13px;
      opacity: .85;
      font-weight: 400;
    }

    .phone{
      margin-top: 2px;
      font-size: 13px;
      font-weight: 700;
      line-height: 1.4;
      opacity: .95;
    }

    .docTitle{
      margin-top: 10px;
      opacity: .92;
      font-size: 14px;
      font-weight: 700;
    }

    .meta{
      text-align: left;
      white-space: nowrap;
      font-size: 12px;
      color: var(--muted);
    }

    .meta b{
      color: var(--text);
    }

    table{
      width: 100%;
      border-collapse: collapse;
      margin-top: 14px;
      font-size: 12px;
      table-layout: fixed;
    }

    colgroup col:nth-child(1){ width: 38%; }
    colgroup col:nth-child(2){ width: 14%; }
    colgroup col:nth-child(3){ width: 16%; }
    colgroup col:nth-child(4){ width: 16%; }
    colgroup col:nth-child(5){ width: 16%; }

    th,
    td{
      border-bottom: 1px solid var(--line);
      padding: 7px;
      vertical-align: top;
      min-width: 0;
    }

    th{
      background: var(--theme);
      color: black;
      font-weight: 700;
      text-align: center;
      white-space: nowrap;
      font-size: 10.5px;
    }

    td.text{
      white-space: normal;
      word-break: break-word;
      overflow-wrap: anywhere;
    }

    td.num{
      white-space: nowrap;
      text-align: center;
    }

    .centerCell{
      text-align: center;
    }

    .totals{
      margin-top: 12px;
      display: flex;
      justify-content: flex-end;
    }

    .totalBox{
      min-width: 260px;
      border: 1px solid var(--theme);
      border-radius: 12px;
      padding: 10px 12px;
      text-align: left;
    }

    .totalRow{
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 13px;
      padding: 4px 0;
    }

    .totalRow strong{
      font-size: 14px;
    }

    .footer{
      margin-top: 18px;
      border-top: 1px dashed #e5e7eb;
      padding-top: 10px;
      color: var(--muted);
      font-size: 11px;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }

    @page{
      size: A4;
      margin: 0;
    }

    @media print{
      html,
      body{
        margin: 0;
        padding: 0;
        background: #fff;
      }

      .page{
        width: 100%;
        min-height: auto;
        margin: 0;
        padding: 12mm;
        box-shadow: none;
        border-radius: 0;
      }
    }
  </style>
</head>

<body>
  <div class="page">

    <div class="header">
      {{#if quote.logoUrl}}
        <img class="logoCorner" src="{{quote.logoUrl}}" alt="logo" />
      {{/if}}

      <div class="topRow">
        <div>
          <div class="biz">{{quote.businessName}}</div>

          {{#if quote.slogan}}
            <div class="slogan">{{quote.slogan}}</div>
          {{/if}}

          {{#if quote.phone}}
            <div class="phone">טלפון: {{quote.phone}}</div>
          {{/if}}
        </div>

        <div class="meta">
          {{#if quote.quoteDate}}
            תאריך: <b>{{quote.quoteDate}}</b><br>
          {{/if}}
        </div>
      </div>
    </div>

    <div class="docTitle">{{quote.title}}</div>

    <table>
      <colgroup>
        <col><col><col><col><col>
      </colgroup>

      <thead>
        <tr>
          <th>מוצר</th>
          <th>כמות מגשים</th>
          <th>יחידות במגש</th>
          <th>מחיר למגש</th>
          <th>סה״כ</th>
        </tr>
      </thead>

      <tbody>
        {{#if quote.items.length}}
          {{#each quote.items}}
            <tr>
              <td class="text">{{this.name}}</td>
              <td class="num">{{this.qty}}</td>
              <td class="text centerCell">{{this.unit}}</td>
              <td class="num">{{formatMoney this.price}}</td>
              <td class="num">{{formatMoney (calcLineTotal this.qty this.price)}}</td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="5" style="text-align:center;opacity:.7;">אין שורות</td>
          </tr>
        {{/if}}
      </tbody>
    </table>

    <div class="totals">
      <div class="totalBox">
        <div class="totalRow">
          <span>סה״כ לתשלום</span>
          <strong>{{formatMoney total}}</strong>
        </div>
      </div>
    </div>

    <div class="footer">
      <div>הערות: המחירים כוללים מע״מ.</div>
      <div>{{quote.businessName}}</div>
    </div>

  </div>
</body>
</html>