<!--api/v1/views/quotes editor.handlebars -->

<div class="container-wide">

<div class="row-between">
  <div>
    <!-- מציג עריכת הצעת מחיר אחרת מציג יצירת הצעת מחיר true הוא isEdit תנאי שאם -->
    <h1 class="h1">{{#if isEdit}}עריכת הצעת מחיר{{else}}יצירת הצעת מחיר{{/if}}</h1>
    <p class="p">הכל נשמר כטיוטה. אפשר לחזור ולערוך בכל זמן.</p>
  </div>
</div>

<br/>

<div class="editor-grid">
  <div class="card">
    <!-- routes/controller הוא החיביר ישירות ל action יוכל למצוא אותו ה js כדי שה post הטופס שולח -->
    <form class="form" method="post" action="{{#if isEdit}}/quotes/{{quote._id}}{{else}}/quotes{{/if}}" id="quoteForm">

      <div class="field">
        <label>שם העסק</label>
        <!-- {{quote.businessName}} מכניס את הערך של שם העסק מהשרת לתוך השדה-->
        <input class="input" name="businessName" value="{{quote.businessName}}" />
      </div>

      <div class="field">
        <label>כותרת</label>
        <input class="input" name="title" value="{{quote.title}}" />
      </div>

      <div class="field">
        <label>תאריך</label>
        <input class="input" name="quoteDate" value="{{quote.quoteDate}}" placeholder="2026-02-10" />
      </div>

      <div class="field">
        <label>תבנית</label>
          <select class="input" name="templateKey">
            <!-- זה משתמש בתבנית הנל quote.templateKey שווה לערך של ה select אם הערך של ה-->
            <!-- שלי handlebars להגדרות view זה מחבר את app.js ב helper מגיע מה eq ה-->
            <option value="sandbox" {{#if (eq quote.templateKey "sandbox")}}selected{{/if}}>Sandbox</option>
            <option value="modern" {{#if (eq quote.templateKey "modern")}}selected{{/if}}>Modern</option>
          </select>
      </div>

      <div class="field">
        <label>צבע</label>
        <input class="color-picker" name="themeColor" type="color" value="{{quote.themeColor}}" />
      </div>

      {{!-- <div class="field">
        <label>Logo URL (בינתיים)</label>
        <input class="input" name="logoUrl" value="{{quote.logoUrl}}" />
      </div> --}}

      <hr style="border:0;border-top:1px solid rgba(148,163,184,.18)"/>

      <div class="row-between">
        <h2 class="h2">שורות</h2>
        <button class="btn" type="button" id="addItemBtn">+ הוסף שורה</button>
      </div>

      <!--מייצר שורות דינמיות dom ב-->
      <div id="itemsArea"></div>

      
      <input type="hidden" name="itemsJson" id="itemsJson" />
      <input type="hidden" name="action" id="actionField" value="save" />

      <div class="row">
        <button class="btn" type="submit" onclick="document.getElementById('actionField').value='save'">
          שמור טיוטה
        </button>

        <button class="btn btn-primary" type="submit" onclick="document.getElementById('actionField').value='saveAndPdf'">
          שמור + הורד PDF
        </button>


        <!-- כפתור הורדה רק בעריכה -->
        {{#if isEdit}}
          <a class="btn" href="/quotes/{{quote._id}}/pdf" target="_blank">📄 הורד PDF</a>
        {{/if}}
        
      </div>
    </form>
  </div>

  <div class="card editor-preview"> <!-- preview של html/css מכניס לשם shadow dom עושה js תצוגה בלייב ה-->
    <div class="row-between">
      <h2 class="h2">תצוגה מקדימה</h2>
      <span class="p">Live Preview</span>
    </div>

    <!-- prewviewbox כל התצוגה בלייב תלויה ב-->
    <div id="previewBox" class="previewBox" style="margin-top:12px;"></div>
  </div>
</div>
</div>
<script>
  // quote אובייקט view השרת נותן ל
  // json.stringify עושה helper json
  // אל תבחר תווים אלה תביא תוכן מלא handlebarsשלושה סוגרים מסולסלים אומר ל
  window.__QUOTE__ = {{{json quote}}};
</script>
<!-- שמגיע מאיזור הסטטים של פאבליק js טעינת ה-->
<script src="/js/quote-editor.js"></script>