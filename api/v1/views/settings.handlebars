<div class="card">
  <div class="stack">
    <h1 class="h1">הגדרות עסק</h1>

    {{#if error}}
      <div class="alert alert-error">{{error}}</div>
    {{/if}}

    <form class="form" method="post" action="/auth/settings" enctype="multipart/form-data">
      <div class="field">
        <label>שם העסק</label>
        <input class="input" name="businessName" value="{{user.businessName}}" />
      </div>

      <div class="field">
        <label>סלוגן אופציונלי</label>
        <input class="input" name="slogan" value="{{user.slogan}}" placeholder="לדוגמה: איכות בלי פשרות" />
      </div>

      <div class="field">
        <label>טלפון אופציונלי</label>
        <input class="input" name="phone" value="{{user.phone}}" placeholder="לדוגמה: 050-1234567" />
      </div>

      <div class="field">
        <label>צבע ברירת מחדל</label>
        <input name="themeColor" type="color" value="{{user.themeColor}}" class="color-picker" />
      </div>

      <div class="field">
        <label>לוגו</label>

        {{#if user.logoPath}}
          <img src="{{user.logoPath}}" class="settings-logo-preview" alt="logo" />
        {{/if}}

        <label class="file-upload-btn">
          בחר לוגו
          <input type="file" name="logo" accept="image/*" hidden />
        </label>
      </div>

      <button class="btn btn-primary" type="submit">שמור הגדרות</button>
    </form>
  </div>
</div>